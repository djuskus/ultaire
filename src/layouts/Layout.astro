---
// src/layouts/Layout.astro — shared shell for all pages
import Nav         from '../components/Nav.astro';
import CloudCanvas from '../components/CloudCanvas.astro';
import Footer      from '../components/Footer.astro';
import '../styles/global.css';

export interface Props {
  title?:       string;
  description?: string;
}

const {
  title       = 'Ultaire',
  description = 'Apps, delivery infrastructure, and a growing library of owned functionality.',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
  <Nav />
  <CloudCanvas />
  <main>
    <slot />
  </main>
  <Footer />
</body>
</html>
