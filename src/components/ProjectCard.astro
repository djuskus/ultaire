---
// ProjectCard.astro
export interface Props {
  category: string;
  name:     string;
  desc:     string;
  tags:     string[];
}
const { category, name, desc, tags } = Astro.props;
---

<article class="project-card">
  <div class="category">{category}</div>
  <h3 class="name">{name}</h3>
  <p class="desc">{desc}</p>
  <ul class="tags" role="list">
    {tags.map(t => <li class="tag">{t}</li>)}
  </ul>
</article>

<style>
  .project-card {
    background: var(--bg);
    padding: 28px;
    transition: background 200ms;
    cursor: default;
  }
  .project-card:hover { background: var(--bg-1); }

  .category {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    color: var(--fg-2);
    margin-bottom: 12px;
  }
  .name {
    font-family: var(--font-sans);
    font-size: 16px;
    font-weight: 700;
    color: var(--fg);
    letter-spacing: -0.01em;
    margin-bottom: 10px;
  }
  .desc {
    font-size: 13px;
    font-weight: 300;
    color: var(--fg-2);
    line-height: 1.6;
    margin-bottom: 18px;
  }
  .tags {
    list-style: none;
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }
  .tag {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--fg-2);
    border: 1px solid var(--fg-3);
    padding: 3px 8px;
    border-radius: 3px;
  }
</style>
