---
// src/pages/about.astro
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="About — Ultaire"
  description="Apps, delivery infrastructure, and a growing library of owned functionality."
>
  <section class="about-section container">
    <div class="inner">
      <div class="section-tag">about</div>
      <h2>Ultaire</h2>
      <div class="body">
        <p>
          We build apps. We build the infrastructure that delivers them.
          We build a growing library of owned functionality — components,
          pipelines, services, and systems — that compounds over time.
        </p>
        <p>
          The work is cumulative. Every product, every tool, every deployed
          service adds to a foundation that makes the next thing faster,
          more capable, and more ours.
        </p>
      </div>

      <div class="pillars">
        <div class="pillar">
          <div class="pillar-label">apps</div>
          <p>Products people use. Built with intention, shipped with care.</p>
        </div>
        <div class="pillar">
          <div class="pillar-label">delivery infrastructure</div>
          <p>The pipelines, environments, and tooling that get code to users reliably.</p>
        </div>
        <div class="pillar">
          <div class="pillar-label">owned functionality</div>
          <p>A library that grows with every project — less rebuilt, more composed.</p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .about-section {
    position: relative;
    z-index: 1;
    padding-top: clamp(100px, 18vw, 180px);
    padding-bottom: clamp(80px, 12vw, 140px);
  }
  .inner { max-width: 560px; }

  h2 { margin-bottom: 28px; }

  .body { display: flex; flex-direction: column; gap: 16px; margin-bottom: 64px; }

  .pillars {
    display: flex;
    flex-direction: column;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }
  .pillar {
    background: var(--bg);
    padding: 24px 24px;
    transition: background 200ms;
  }
  .pillar:hover { background: var(--bg-1); }
  .pillar-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.2);
    margin-bottom: 10px;
  }
  .pillar p {
    font-size: 14px;
    color: rgba(255,255,255,0.35);
    line-height: 1.65;
  }
</style>
